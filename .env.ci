# .env.ci
# Variables d'environnement — Execution CI/CD GitHub Actions
# Ce fichier est utilise comme reference — les vraies valeurs
# sont injectees via les secrets GitHub Actions

# URL de la SPA servie par npx serve en CI
BASE_URL=http://localhost:3000

# Mode headless obligatoire en CI
HEADLESS=true

# Timeout augmente pour les runners CI
TIMEOUT=30000

# 1 retry autorise en CI
RETRIES=1

# Nom de l'environnement
ENV_NAME=ci